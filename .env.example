# Bridge Server
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=47302

# Trading
SYMBOLS=XAUUSDm
LOT_SIZE=0.01
MAX_DAILY_LOSS=3500
MAX_POSITIONS_PER_SYMBOL=1
MAX_TOTAL_POSITIONS=1

# SR Zone
SR_TIMEFRAME=M15
SR_BARS=100
SR_ZONE_THRESHOLD_POINTS=150
SR_ZONE_MERGE_POINTS=300

# Risk
RISK_PERCENT=1.0
MAX_SPREAD_POINTS=500
MIN_RR_RATIO=1.5
ENTRY_INTERVAL_SECONDS=120

# Trend
EMA_FAST=20
EMA_SLOW=50
MIN_CANDLE_BODY_POINTS=50

# Pyramid
PYRAMID_ENABLED=false
PYRAMID_MAX_LEVELS=2
PYRAMID_TRIGGER_POINTS=200
PYRAMID_LOT_MULTIPLIER=0.5
PYRAMID_MIN_LOT=0.01

# Fibonacci
FIB_ENABLED=true
FIB_SWING_LOOKBACK=50
FIB_ENTRY_LEVELS=0.382,0.5,0.618
FIB_TP_EXTENSION=1.272,1.618
FIB_CONFLUENCE_BUFFER=150

# Cooldown
LOSS_COOLDOWN_ENABLED=true
LOSS_COOLDOWN_TRIGGER=1
LOSS_COOLDOWN_MINUTES=60

# Trailing SL
TRAILING_SL_ENABLED=true
TRAILING_SL_POINTS=150
TRAILING_SL_STEP_POINTS=10

# Break Even
BREAK_EVEN_ENABLED=true
BREAK_EVEN_TRIGGER_POINTS=80
BREAK_EVEN_BUFFER_POINTS=5

# Partial Close
PARTIAL_CLOSE_ENABLED=true
PARTIAL_CLOSE_TRIGGER_POINTS=120
PARTIAL_CLOSE_RATIO=0.5

# EOD Close
EOD_CLOSE_ENABLED=true
EOD_HOUR=23
EOD_MINUTE=50

# Session Filter
SESSION_FILTER_ENABLED=true
SESSION_OPEN_HOUR=14
SESSION_CLOSE_HOUR=16

# News Filter
NEWS_FILTER_ENABLED=true
NEWS_BLACKOUT_BEFORE_MIN=15
NEWS_BLACKOUT_AFTER_MIN=15

# DXY Filter
DXY_FILTER_ENABLED=true
DXY_REFRESH_SECONDS=300
DXY_TREND_THRESHOLD=0.15
